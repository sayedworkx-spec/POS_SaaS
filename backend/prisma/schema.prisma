generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  cashier
  warehouse
}

enum PaymentMethod {
  cash
  card
}

enum CashMovementType {
  IN
  OUT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(cashier)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id           Int      @id @default(autoincrement())
  sku          String   @unique
  barcode      String   @unique
  name         String
  categoryId   Int
  stock        Int      @default(0)
  costPrice    Float    @default(0)
  sellPrice    Float    @default(0)
  reorderLevel Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Sale {
  id              Int            @id @default(autoincrement())
  invoiceNumber   String         @unique
  saleDate        DateTime
  cashier         String
  shiftId         Int
  paymentMethod   PaymentMethod
  subtotal        Float
  costTotal       Float
  profit          Float
  discountPercent Float          @default(0)
  discountAmount  Float          @default(0)
  total           Float
  cashReceived    Float          @default(0)
  change          Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           SaleItem[]
  returns         SalesReturn[]
}

model SaleItem {
  id         Int      @id @default(autoincrement())
  saleId     Int
  productId  Int
  sku        String
  name       String
  quantity   Int
  unitPrice  Float
  costPrice  Float
  lineTotal  Float
  costTotal  Float
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model SalesReturn {
  id            Int               @id @default(autoincrement())
  returnNumber  String            @unique
  returnDate    DateTime
  saleId        Int
  invoiceNumber String
  cashier       String
  reason        String
  refundMethod  PaymentMethod
  shiftId       Int?
  subtotal      Float
  refundAmount  Float
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  sale          Sale              @relation(fields: [saleId], references: [id], onDelete: Restrict)
  items         SalesReturnItem[]
}

model SalesReturnItem {
  id          Int          @id @default(autoincrement())
  returnId    Int
  productId   Int
  sku         String
  name        String
  quantity    Int
  unitPrice   Float
  refundTotal Float

  salesReturn SalesReturn  @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model CashShift {
  id          Int           @id @default(autoincrement())
  userId      Int?
  userName    String
  openingCash Float
  closingCash Float?
  actualCash  Float?
  difference  Float?
  status      String        @default("open")
  openedAt    DateTime      @default(now())
  closedAt    DateTime?
  movements   CashMovement[]
}

model CashMovement {
  id        Int               @id @default(autoincrement())
  shiftId   Int?
  shift     CashShift?        @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  type      CashMovementType
  amount    Float
  note      String
  createdAt DateTime          @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  username  String
  details   String
  createdAt DateTime @default(now())
}